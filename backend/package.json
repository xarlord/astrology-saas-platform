{
  "name": "@astrology-saas/backend",
  "version": "1.0.0",
  "description": "Backend API for Astrology SaaS Platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:performance": "jest --testPathPattern=performance",
    "test:unit": "jest --testPathPattern='(?!performance|integration)'",
    "test:integration": "jest --config=jest.integration.config.js",
    "test:live": "jest --testPathPattern='live/' --testPathIgnorePatterns=[] --testTimeout=60000 --forceExit --verbose",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "db:migrate": "knex migrate:latest",
    "db:rollback": "knex migrate:rollback",
    "db:seed": "knex seed:run",
    "db:reset": "knex migrate:rollback && knex migrate:latest && knex seed:run"
  },
  "dependencies": {
    "@astrology-saas/shared-types": "*",
    "@types/multer": "^2.1.0",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/ui": "4.1.8",
    "astronomy-engine": "^2.1.19",
    "axios": "^1.6.5",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.76.5",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-csrf": "^4.0.3",
    "date-fns": "^3.0.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "luxon": "^3.7.2",
    "multer": "^2.1.1",
    "openai": "^6.22.0",
    "pg": "^8.11.3",
    "puppeteer": "^24.40.0",
    "resend": "^6.12.2",
    "sanitize-html": "^2.17.4",
    "stripe": "^22.1.0",
    "swagger-jsdoc": "^6.2.8",
    "swisseph": "^0.5.17",
    "uuid": "^14.0.0",
    "vite": "8.0.16",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.8",
    "web-push": "^3.6.7",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/luxon": "^3.7.1",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.10.9",
    "@types/puppeteer": "^5.4.7",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@typescript-eslint/tsconfig-utils": "^8.57.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
