{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "jest",
  "coverageAnalysis": "perTest",
  "reporters": ["html", "clear-text", "progress", "dashboard"],
  "mutate": [
    "src/**/*.ts",
    "!src/**/*.d.ts",
    "!src/**/*.interface.ts",
    "!src/**/*.type.ts",
    "!src/**/__tests__/**",
    "!src/server.ts",
    "!src/app.ts",
    "!src/**/solar/**",
    "!src/utils/swisseph.stub.ts"
  ],
  "jest": {
    "configFile": "./jest.mutation.config.js"
  },
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 70
  },
  "concurrency": 4,
  "timeoutMS": 60000,
  "timeoutFactor": 2.0,
  "ignoreStatic": true,
  "dashboard": {
    "project": "github.com/your-org/astrology-saas-platform",
    "version": "backend"
  }
}
