{
  "permissions": {
    "allow": [
      "Bash(npx jest:*)",
      "Bash(npx vitest:*)",
      "Bash(npx playwright:*)",
      "Bash(npx tsc:*)",
      "Bash(npx eslint:*)",
      "Bash(npx knex:*)",
      "Bash(npx prettier:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run build:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run db:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(ls:*)",
      "Bash(pg_isready:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(curl:*)",
      "WebSearch",
      "mcp__*"
    ],
    "deny": [
      "Edit(.env*)",
      "Write(.env*)",
      "Read(.env)",
      "Write(**/.env)",
      "Edit(**/.env)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git checkout:*)",
      "Bash(docker rm:*)",
      "Bash(docker compose down:*)",
      "Bash(npm publish:*)",
      "Bash(taskkill:*)",
      "Bash(kill:*)"
    ]
  },
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File .claude/hooks/notify.ps1",
            "timeout": 5000,
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File .claude/hooks/guard-env.ps1",
            "timeout": 3000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File .claude/hooks/format.ps1",
            "timeout": 5000,
            "async": true
          }
        ]
      }
    ]
  },
  "plansDirectory": "./.planning"
}