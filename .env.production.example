# ============================================
# AstroVerse — Production Environment Config
# ============================================
# Copy to .env and fill in real values before deploying.

# ---- Application ----
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://astroverse.app
API_URL=https://api.astroverse.app

# ---- Database ----
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=astrology_saas
DATABASE_USER=astrology
DATABASE_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>
DATABASE_URL=postgresql://astrology:<CHANGE_ME>@db:5432/astrology_saas

# ---- Authentication ----
JWT_SECRET=<CHANGE_ME_64_CHAR_RANDOM_STRING>
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ---- Stripe (Payments) ----
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# ---- AI Services ----
OPENAI_API_KEY=sk-...

# ---- OAuth (Optional) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Monitoring ----
SENTRY_DSN=https://...@sentry.io/...

# ---- SSL (mounted in Docker) ----
SSL_CERT_PATH=/etc/ssl/certs
SSL_KEY_PATH=/etc/ssl/private
