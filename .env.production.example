# Production Environment Configuration
# Astrology SaaS Platform - Production

# Application
NODE_ENV=production
PORT=3001
LOG_LEVEL=info

# CORS - Production URLs
# Replace with your actual production domain
FRONTEND_URL=https://yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Database - PostgreSQL
# Use DATABASE_URL or individual DB vars
# DATABASE_URL=postgresql://user:pass@host:5432/db_name
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT - PRODUCTION SECRET
# IMPORTANT: Generate a secure random secret for production!
# Use: openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_MIN_32_CHARACTERS
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CSRF Protection
# Generate with: openssl rand -base64 32
CSRF_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING

# Swiss Ephemeris
EPHEMERIS_PATH=./ephemeris

# Rate Limiting - Production
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Frontend API URL (set to backend URL)
VITE_API_URL=https://your-backend-url.example.com

# Optional: Email (Postmark/SendGrid)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourdomain.com

# Optional: Redis (for caching/sessions)
REDIS_URL=

# Optional: OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-backend-url.example.com/auth/google/callback

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
