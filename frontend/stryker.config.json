{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "coverageAnalysis": "perTest",
  "reporters": ["html", "clear-text", "progress", "dashboard"],
  "mutate": [
    "src/**/*.{ts,tsx}",
    "!src/**/*.d.ts",
    "!src/**/__tests__/**",
    "!src/**/*.config.*",
    "!src/main.tsx",
    "!src/vite-env.d.ts"
  ],
  "vitest": {
    "configFile": "./vitest.config.ts"
  },
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 70
  },
  "concurrency": 4,
  "timeoutMS": 60000,
  "timeoutFactor": 2.0,
  "ignoreStatic": true,
  "dashboard": {
    "project": "github.com/your-org/astrology-saas-platform",
    "version": "frontend"
  }
}
