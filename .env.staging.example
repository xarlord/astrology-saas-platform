# AstroVerse Staging Environment Variables
# Copy to .env.staging and fill in values before deploying
#
# For Docker Compose staging (local):
#   cp .env.staging.example .env.staging
#   docker compose -f docker-compose.staging.yml up --build
#
# For Railway staging (remote):
#   Set these in the Railway project dashboard

# --- Server ---
NODE_ENV=staging
PORT=3001
FRONTEND_URL=http://localhost
LOG_LEVEL=debug
LOG_FORMAT=json

# --- Database ---
# Docker Compose: use individual vars (postgres container doesn't use SSL)
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=astrology_staging
DATABASE_USER=staging_user
DATABASE_PASSWORD=staging_password_change_me
DATABASE_SSL=false

# Railway: use DATABASE_URL (auto-provisioned with PostgreSQL addon)
# DATABASE_URL=postgresql://staging_user:PASSWORD@HOST:5432/astrology_staging

DB_POOL_MIN=2
DB_POOL_MAX=10

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Authentication ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=staging-jwt-secret-minimum-32-characters-long-for-security
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# --- Frontend (build-time for Vite) ---
# Leave empty for Docker Compose (nginx proxies /api to backend)
# Set to backend URL for Railway deployment
VITE_API_URL=

# --- CORS ---
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:3001

# --- Swiss Ephemeris ---
EPHEMERIS_PATH=./ephemeris

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# --- Optional Services ---
# GOOGLE_PLACES_API_KEY=
# RESEND_API_KEY=
# OPENAI_API_KEY=
