# AstroVerse Staging Environment Variables
# Copy to .env.staging and fill in values before deploying

# --- Server ---
NODE_ENV=staging
PORT=3001
FRONTEND_URL=https://astrology-staging.up.railway.app
LOG_LEVEL=debug
LOG_FORMAT=json

# --- Database ---
# Use DATABASE_URL for Railway (auto-provisioned with PostgreSQL addon)
DATABASE_URL=postgresql://staging_user:PASSWORD@HOST:5432/astrology_staging
DATABASE_HOST=localhost
DATABASE_PORT=5434
DATABASE_NAME=astrology_staging
DATABASE_USER=staging_user
DATABASE_PASSWORD=
DB_POOL_MIN=2
DB_POOL_MAX=10

# --- Authentication ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# --- Frontend (build-time for Vite) ---
VITE_API_URL=https://astrology-backend-staging.up.railway.app

# --- CORS ---
ALLOWED_ORIGINS=https://astrology-staging.up.railway.app,http://localhost:3000

# --- Swiss Ephemeris ---
EPHEMERIS_PATH=./ephemeris

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# --- Optional Services ---
# GOOGLE_PLACES_API_KEY=
# RESEND_API_KEY=
# OPENAI_API_KEY=
